# Copy this file to config/pingpong_demo.env on the robot and edit local values.

# auto: use the first available /dev/video0 or /dev/video1.
# usb0: force /dev/video0.
# usb1: force /dev/video1.
# topic: use an existing ROS2 image topic and do not start v4l2_camera.
CAMERA_PROFILE=auto

# Used only when CAMERA_PROFILE=topic.
IMAGE_TOPIC=/camera/camera/color/image_raw

# auto: ordinary USB camera disables depth; topic mode enables depth when
# DEPTH_IMAGE_TOPIC is not empty.
# true: force depth sampling.
# false: force z=0.
USE_DEPTH=auto
DEPTH_IMAGE_TOPIC=/camera/camera/aligned_depth_to_color/image_raw
DEPTH_WINDOW_PX=5

# Standard TrayMatrix output configuration.
EXPECTED_TRAY_COUNT=3
PROCESS_EVERY_N_FRAMES=3

# TCP target for sorting_driver/matrix_tcp_sender.
# Fill in the real F407/W5500 IP before hardware testing.
F407_HOST=192.168.1.50
F407_PORT=9000

# Keep this enabled for real hardware tests. The launcher will stop before
# starting ROS2 if the F407 TCP endpoint is not reachable.
CHECK_F407=1
