# 将本文件复制为 config/pingpong_demo.env 后，在鲁班猫上按现场硬件修改参数。

# auto：优先识别 D435iF/RealSense；否则自动使用第一个可用的 /dev/video0 或 /dev/video1。
# usb0：强制使用 /dev/video0。
# usb1：强制使用 /dev/video1。
# realsense：启动 realsense2_camera，订阅 D435iF RGB，并使用对齐深度。
# topic：不启动 v4l2_camera，直接订阅已有 ROS2 图像 topic。
CAMERA_PROFILE=auto

# 仅 CAMERA_PROFILE=topic 时使用。
IMAGE_TOPIC=/camera/camera/color/image_raw
COLOR_CAMERA_INFO_TOPIC=/camera/camera/color/camera_info

# auto：普通 USB 相机自动关闭深度；realsense 模式自动启用深度；topic 模式且 DEPTH_IMAGE_TOPIC 非空时启用深度。
# true：强制采样深度。
# false：强制 z=0。
USE_DEPTH=auto
DEPTH_IMAGE_TOPIC=/camera/camera/aligned_depth_to_color/image_raw
DEPTH_WINDOW_PX=5

# true：鲁班猫端读取 RGB CameraInfo，用 OpenCV undistortPoints() 校正 u/v 后发给 F407。
# false：直接发送原图 u/v，不做畸变校正。
USE_UNDISTORT=true

# D435iF/RealSense 分辨率和帧率。格式：宽x高xFPS。
# 提高分辨率会增加识别计算量；提高 FPS 会增加 ROS2 和 CPU 压力。
REALSENSE_COLOR_PROFILE=640x480x15
REALSENSE_DEPTH_PROFILE=640x480x15

# 标准 TrayMatrix 输出配置。这里是最多识别盘数，不要求画面里必须有这么多盘。
EXPECTED_TRAY_COUNT=3
PROCESS_EVERY_N_FRAMES=3

# 三盘并排时，两个苗盘可能被黑色主体检测粘成一个宽框。
# true 会把明显过宽的大黑框按单盘宽度拆开，优先用于三盘乒乓球现场测试。
SPLIT_WIDE_LARGE_DARK_RECTS=true
LARGE_DARK_MAX_SINGLE_WIDTH_RATIO=0.36
RELAX_SPLIT_STRUCTURE=true

# 整帧苗盘几何检测参数。左/右边缘盘漏检时，优先轻微放宽这些值。
# GEOMETRY_METHOD 当前建议保持 large_dark_rect，这是三盘并排测试里较稳的黑色苗盘主体检测。
# GEOMETRY_DARK_THRESHOLD 越大，越容易把较亮的黑盘纳入候选，但也更容易吃到阴影。
# GEOMETRY_PROJECTION_* 用于老的投影拆分方法；当前默认方法主要保留为可回退参数。
# *_RATIO 是相对整张 640x480 图的宽高/面积比例。
GEOMETRY_METHOD=large_dark_rect
GEOMETRY_DARK_THRESHOLD=85
GEOMETRY_PROJECTION_ACTIVE_RATIO=0.10
GEOMETRY_PROJECTION_SMOOTH_PX=19
GEOMETRY_MIN_WIDTH_RATIO=0.08
GEOMETRY_MIN_HEIGHT_RATIO=0.35
GEOMETRY_MIN_AREA_RATIO=0.025
GEOMETRY_X_PADDING_PX=10
GEOMETRY_MORPHOLOGY_KERNEL_PX=17
GEOMETRY_EDGE_ROI_PADDING_PX=12

# 单盘四边拟合/透视矫正参数。检测到候选框但显示 partial_edges 时再调这里。
DARK_THRESHOLD=95
CLOSE_KERNEL_RATIO=0.045
MIN_AREA_RATIO=0.16
SIDE_BAND_RATIO=0.075

# 单穴位颜色采样半径。调大更容易吃到偏心球，也更容易吃到邻格/孔边。
ROI_RADIUS_RATIO=0.34

# 白球识别阈值。空穴里的浅色小圆点容易误判白球时，优先调高这两个值；
# 如果真实白球漏检，再适当调低。默认值偏保守，用来压空穴亮点误检。
MIN_WHITE_RATIO=0.36
MIN_WHITE_COMPONENT_RATIO=0.30
# 白球形状过滤。用于压制空穴白点误检；默认值保守，不改变黄色球逻辑。
MIN_WHITE_SHAPE_COMPONENT_RATIO=0.18
MIN_WHITE_COMPONENT_DIAMETER_RATIO=0.95
MIN_WHITE_CIRCULARITY=0.35
MAX_WHITE_CENTER_OFFSET_RATIO=0.55

# 黄球识别阈值。
# MIN_BALL_RATIO 是黄球候选的最小黄色面积比例；调低更灵敏，调高更保守。
MIN_BALL_RATIO=0.16
# 黄球最大连通域比例；调高可减少零散黄色反光误判，但可能漏检黄球。
MIN_YELLOW_COMPONENT_RATIO=0.12
# 黄白颜色比例差；用于避免黄白都接近时乱判。
MIN_COLOR_MARGIN=0.035

# sorting_driver/matrix_tcp_sender 的 TCP 目标。
# 真实硬件测试前必须改成 F407/W5500 的真实 IP。
F407_HOST=192.168.1.50
F407_PORT=9000

# 真实硬件测试建议保持开启。若 F407 TCP 端点不可达，启动器会在启动 ROS2 前停止。
CHECK_F407=1
