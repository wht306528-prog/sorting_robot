# 将本文件复制为 config/pingpong_demo.env 后，在鲁班猫上按现场硬件修改参数。

# auto：优先识别 D435iF/RealSense；否则自动使用第一个可用的 /dev/video0 或 /dev/video1。
# usb0：强制使用 /dev/video0。
# usb1：强制使用 /dev/video1。
# realsense：启动 realsense2_camera，订阅 D435iF RGB，并使用对齐深度。
# topic：不启动 v4l2_camera，直接订阅已有 ROS2 图像 topic。
CAMERA_PROFILE=auto

# 仅 CAMERA_PROFILE=topic 时使用。
IMAGE_TOPIC=/camera/camera/color/image_raw
COLOR_CAMERA_INFO_TOPIC=/camera/camera/color/camera_info

# auto：普通 USB 相机自动关闭深度；realsense 模式自动启用深度；topic 模式且 DEPTH_IMAGE_TOPIC 非空时启用深度。
# true：强制采样深度。
# false：强制 z=0。
USE_DEPTH=auto
DEPTH_IMAGE_TOPIC=/camera/camera/aligned_depth_to_color/image_raw
DEPTH_WINDOW_PX=5

# true：鲁班猫端读取 RGB CameraInfo，用 OpenCV undistortPoints() 校正 u/v 后发给 F407。
# false：直接发送原图 u/v，不做畸变校正。
USE_UNDISTORT=true

# D435iF/RealSense 分辨率和帧率。格式：宽x高xFPS。
# 提高分辨率会增加识别计算量；提高 FPS 会增加 ROS2 和 CPU 压力。
REALSENSE_COLOR_PROFILE=640x480x15
REALSENSE_DEPTH_PROFILE=640x480x15

# 标准 TrayMatrix 输出配置。这里是最多识别盘数，不要求画面里必须有这么多盘。
EXPECTED_TRAY_COUNT=3
PROCESS_EVERY_N_FRAMES=3

# sorting_driver/matrix_tcp_sender 的 TCP 目标。
# 真实硬件测试前必须改成 F407/W5500 的真实 IP。
F407_HOST=192.168.1.50
F407_PORT=9000

# 真实硬件测试建议保持开启。若 F407 TCP 端点不可达，启动器会在启动 ROS2 前停止。
CHECK_F407=1
